# ── CiteReady Environment Variables ──

# App
APP_NAME=CiteReady
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# Database (SQLite default, switch to PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./data/citeready.db

# LLM API Keys / Providers
LLM_MODEL=ollama/llama3.1
OLLAMA_API_BASE=http://localhost:11434

# ANTHROPIC_API_KEY=sk-ant-... (For production fallback)
# OPENAI_API_KEY=sk-...

# Optional: Redis Cache (Phase 2+)
# REDIS_URL=redis://localhost:6379/0
