# ── CiteReady Environment Variables ──

# App
APP_NAME=CiteReady
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# Database (SQLite default, switch to PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./data/citeready.db

# ========================================
# SECURITY & CORS (Production Only)
# ========================================
# Comma-separated list of allowed frontend domains. Use "*" for local dev.
FRONTEND_CORS_ORIGINS=http://localhost:3000

# ========================================
# AI PROVIDER SETTINGS (Local vs Cloud)
# ========================================
# Supported providers via LiteLLM: 'ollama', 'openai', 'anthropic', etc.
LLM_PROVIDER=ollama
LLM_MODEL=ollama/llama3.1
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=
LLM_TIMEOUT=45

# For OpenAI Production Example:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=
# LLM_API_KEY=sk-proj-your-api-keysk-...

# Optional: Redis Cache (Phase 2+)
# REDIS_URL=redis://localhost:6379/0
